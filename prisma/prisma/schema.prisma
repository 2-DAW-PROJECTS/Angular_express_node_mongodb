// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
  relationMode = "prisma"
}

model UserEnterprise {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userType    String   @default("Enterprise")
  isActive    Boolean  @default(true)
  username    String
  email       String   @unique
  password    String
  timestamp   DateTime @default(now())
  permissions String[]
  telefon     String
  followers   String[]
  offerts     Offert[] // This establishes the relation with Offert model
}

model Offert {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  userEnterprise  UserEnterprise @relation(fields: [userEnterpriseId], references: [id])
  userEnterpriseId String   @db.ObjectId
  applications    Application[]
}

model Application {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  offert    Offert   @relation(fields: [offertId], references: [id])
  offertId  String   @db.ObjectId
  userId    String
  timestamp DateTime @default(now())
  status    String
}
